<DocsPage MaxWidth="MaxWidth.Large" ShowContentDrawer="false">
    @if (Repository is null)
    {
        <MudGrid Justify="Justify.Center">
            <MudProgressCircular Color="Color.Primary"
                                 Size="Size.Medium"
                                 Indeterminate="true" />
        </MudGrid>
    }
    else
    {
        <RepositoryDetailHeader Repository="@Repository" />

        <MudTabs ActivePanelIndex="@activeTabIndex"
                 ActivePanelIndexChanged="OnTabChanged"
                 Elevation="0"
                 Rounded="true"
                 ApplyEffectsToContainer="true"
                 Class="repo-detail-tabs mb-6"
                 TabPanelsClass="pt-4">

            @* ===== README Tab ===== *@
            <MudTabPanel Text="README" Icon="@Icons.Material.Filled.Description">
                <RepositoryTabPanelWithSidebar Repository="@Repository">
                    <MudCard Elevation="0">
                        @if (Repository.Root.HasReadme)
                        {
                            <MudCardContent>
                                <MarkdownRepositoryContent RepositoryName="@Repository.Name"
                                                           RepositoryBranch="@Repository.BaseData.DefaultBranch"
                                                           IdPrefix="readme"
                                                           Content="@Repository.Root.RawReadme" />
                            </MudCardContent>
                        }
                        else
                        {
                            <MudCardContent>
                                <MudProgressCircular Color="Color.Primary"
                                                     Size="Size.Small"
                                                     Indeterminate="true" />
                            </MudCardContent>
                        }
                    </MudCard>
                </RepositoryTabPanelWithSidebar>
            </MudTabPanel>

            @* ===== Changelog Tab ===== *@
            @if (Repository.Root.HasChangelog)
            {
                <MudTabPanel Text="Changelog" Icon="@Icons.Material.Filled.History">
                    <RepositoryTabPanelWithSidebar Repository="@Repository">
                        <MudCard Elevation="0">
                            <MudCardContent>
                                <MarkdownRepositoryContent RepositoryName="@Repository.Name"
                                                           RepositoryBranch="@Repository.BaseData.DefaultBranch"
                                                           IdPrefix="changelog"
                                                           Content="@Repository.Root.RawChangelog" />
                            </MudCardContent>
                        </MudCard>
                    </RepositoryTabPanelWithSidebar>
                </MudTabPanel>
            }

            @* ===== Documentation (Wiki) Tab ===== *@
            @if (Repository.Wiki.HasWiki)
            {
                <MudTabPanel Text="Documentation" Icon="@Icons.Material.Filled.MenuBook">
                    <RepositoryWikiTab Repository="@Repository" />
                </MudTabPanel>
            }

            @* ===== Dependencies Tab ===== *@
            @if (Repository.NugetInfo?.DependencyGroups.Count > 0)
            {
                <MudTabPanel Text="Dependencies" Icon="@Icons.Material.Filled.AccountTree">
                    <RepositoryTabPanelWithSidebar Repository="@Repository">
                        <RepositoryDependenciesTab Repository="@Repository" />
                    </RepositoryTabPanelWithSidebar>
                </MudTabPanel>
            }

        </MudTabs>
    }
</DocsPage>