@inherits DocsPageRepositoryBase

<DocsPage MaxWidth="MaxWidth.Large">
    @if (Repository is null)
    {
        <MudGrid Justify="Justify.Center">
            <MudProgressCircular Color="Color.Primary"
                                 Size="Size.Medium"
                                 Indeterminate="true" />
        </MudGrid>
    }
    else
    {
        <DocsPageHeader Title="@Repository.Name"
                        TitleLink="@($"https://github.com/atc-net/{Repository.Name}")">
            <Description>
                <RepositoryDescription Repository="@Repository" />
            </Description>
        </DocsPageHeader>
        <DocsPageContent>
            <DocsPageSection>
                <SectionHeader Title="Readme" />
                <SectionContent AutoMarginContent="false"
                                FullWidth="true">
                    <MudCard Elevation="0">
                        @if (Repository.Root.HasReadme)
                        {
                            <MudCardContent>
                                <MarkdownRepositoryContent RepositoryName="@Repository.Name"
                                                           RepositoryBranch="@Repository.BaseData.DefaultBranch"
                                                           Content="@Repository.Root.RawReadme" />
                            </MudCardContent>
                        }
                        else
                        {
                            <MudCardContent>
                                <MudProgressCircular Color="Color.Primary"
                                                     Size="Size.Small"
                                                     Indeterminate="true" />
                            </MudCardContent>
                        }
                    </MudCard>
                </SectionContent>
            </DocsPageSection>
            @if (Repository.Wiki.HasWiki)
            {
                <DocsPageSection>
                    <SectionHeader Title="Wiki" />
                    <SectionContent AutoMarginContent="false" FullWidth="true">
                        @foreach (var wikiPage in Repository.Wiki.Pages)
                        {
                            <DocsPageSection>
                                <SectionHeader Title="@wikiPage.Title" />
                                <SectionContent AutoMarginContent="false" FullWidth="true">
                                    <MudCard Elevation="0">
                                        @if (wikiPage.IsLoaded)
                                        {
                                            <MudCardContent>
                                                <MarkdownRepositoryContent RepositoryName="@Repository.Name"
                                                                           RepositoryBranch="@Repository.BaseData.DefaultBranch"
                                                                           Content="@wikiPage.RawContent" />
                                            </MudCardContent>
                                        }
                                        else
                                        {
                                            <MudCardContent>
                                                <MudProgressCircular Color="Color.Primary"
                                                                     Size="Size.Small"
                                                                     Indeterminate="true" />
                                            </MudCardContent>
                                        }
                                    </MudCard>
                                </SectionContent>
                            </DocsPageSection>
                        }
                    </SectionContent>
                </DocsPageSection>
            }
            @if (Repository.IsDotnetSolution && Repository.Dotnet is not null)
            {
                foreach (var dotnetProject in Repository.Dotnet.Projects
                    .OrderBy(x => x.Name))
                {
                    if (dotnetProject.HasReadme)
                    {
                        <DocsPageSection>
                            <SectionHeader Title="@dotnetProject.Name"/>
                            <SectionContent AutoMarginContent="false"
                                            FullWidth="true">
                                <MudCard Elevation="0">
                                    <MudCardContent>
                                        <MarkdownRepositoryContent RepositoryName="@Repository.Name"
                                                                   RepositoryBranch="@Repository.BaseData.DefaultBranch"
                                                                   HeaderName="@dotnetProject.Name"
                                                                   Content="@dotnetProject.RawReadme"/>
                                    </MudCardContent>
                                </MudCard>
                            </SectionContent>
                        </DocsPageSection>
                    }
                }
            }
        </DocsPageContent>
    }
</DocsPage>