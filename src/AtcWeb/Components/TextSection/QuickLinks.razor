<DocsPageSection>
    <SectionHeader Title="Quick links" />
    <SectionContent AutoMarginContent="false" FullWidth="true">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="3">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Custom.Brands.GitHub"
                           Href="https://github.com/atc-net" Target="_blank"
                           Style="text-transform: none; justify-content: start;">
                    GitHub Organization
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.CloudDownload"
                           Href="https://www.nuget.org/packages?q=owner%3Aatc-net" Target="_blank"
                           Style="text-transform: none; justify-content: start;">
                    NuGet Packages
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Tertiary"
                           StartIcon="@Icons.Material.Filled.Rule"
                           Href="https://github.com/atc-net/atc-coding-rules" Target="_blank"
                           Style="text-transform: none; justify-content: start;">
                    Coding Rules
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.MenuBook"
                           Href="/manuals/devops-playbook"
                           Style="text-transform: none; justify-content: start;">
                    DevOps Playbook
                </MudButton>
            </MudItem>
        </MudGrid>
    </SectionContent>
</DocsPageSection>