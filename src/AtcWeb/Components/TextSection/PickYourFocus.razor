                    <div class="feature-description">
                        Explore <strong>10+ dotnet tools</strong> for code generation, project scaffolding,
                        and developer workflows.
                    </div>
                </a>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <a href="/introduction/repository-overview?category=Core%20%26%20Libraries" class="focus-card" style="text-decoration: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Hub"
                             Class="feature-icon" Style="color: #ffa800;" />
                    <div class="feature-title">Core Libraries?</div>
                    <div class="feature-description">
                        Foundational packages like <strong>atc-hosting</strong>,
                        <strong>atc-kusto</strong>, and <strong>atc-azure-messaging</strong> for everyday .NET development.
                    </div>
                </a>
            </MudItem>
        </MudGrid>
