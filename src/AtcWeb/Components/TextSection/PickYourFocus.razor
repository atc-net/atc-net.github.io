<DocsPageSection>
    <SectionHeader Title="Pick your focus" />
    <SectionContent AutoMarginContent="false" FullWidth="true">
        <MudText Class="mb-4">
            ATC-NET covers a wide range of .NET development needs. Pick an area to explore the most relevant packages and tools.
        </MudText>
        <MudGrid Spacing="4">
            <MudItem xs="12" sm="6" md="4">
                <a href="/introduction/repository-overview?category=REST%20%26%20API" class="focus-card" style="text-decoration: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Api"
                             Class="feature-icon" Style="color: #ff4081;" />
                    <div class="feature-title">Building APIs?</div>
                    <div class="feature-description">
                        Generate REST endpoints, clients, and OpenAPI specs with
                        <strong>atc-rest-api-source-generator</strong> and <strong>atc-rest-minimalapi</strong>.
                    </div>
                </a>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <a href="/introduction/repository-overview?category=Code%20Quality" class="focus-card" style="text-decoration: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Rule"
                             Class="feature-icon" Style="color: #1ec8a5;" />
                    <div class="feature-title">Code Quality?</div>
                    <div class="feature-description">
                        Enforce consistent standards across your repos with
                        <strong>atc-coding-rules</strong> and the <strong>coding-rules-updater</strong> CLI.
                    </div>
                </a>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <a href="/introduction/repository-overview?category=AI%20%26%20Agents" class="focus-card" style="text-decoration: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Psychology"
                             Class="feature-icon" Style="color: #776be7;" />
                    <div class="feature-title">AI & Agents?</div>
                    <div class="feature-description">
                        Build agentic workflows with <strong>atc-agentic-toolkit</strong>,
                        <strong>atc-semantic-kernel</strong>, and <strong>atc-claude-kanban</strong>.
                    </div>
                </a>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <a href="/introduction/repository-overview?category=IoT,Industrial" class="focus-card" style="text-decoration: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Sensors"
                             Class="feature-icon" Style="color: #4caf50;" />
                    <div class="feature-title">IoT & Industrial?</div>
                    <div class="feature-description">
                        Connect OPC UA, Kepware, and Azure IoT with
                        <strong>atc-opc-ua</strong>, <strong>atc-kepware</strong>, and <strong>atc-azure-iot</strong>.
                    </div>
                </a>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <a href="/tools/cli-tools" class="focus-card" style="text-decoration: none;">
