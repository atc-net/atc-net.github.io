<DocsPageSection>
    <SectionHeader Title="How to contribute" />
    <SectionContent AutoMarginContent="false" FullWidth="true">
        <MudText Class="mb-3">
            We use the standard "fork-and-pull" Git workflow:
        </MudText>
        <MudGrid Spacing="4" Class="mb-4">
            <MudItem xs="12" sm="6" md="4">
                <div class="feature-card" style="height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.ForkRight"
                             Class="feature-icon" Style="color: #776be7;" />
                    <div class="feature-title">1. Fork & Clone</div>
                    <div class="feature-description">
                        Fork the repo on GitHub, then clone it to your machine.
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <div class="feature-card" style="height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.EditNote"
                             Class="feature-icon" Style="color: #1ec8a5;" />
                    <div class="feature-title">2. Branch & Code</div>
                    <div class="feature-description">
                        Create a branch, make your changes, and commit to your fork.
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <div class="feature-card" style="height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.RateReview"
                             Class="feature-icon" Style="color: #ff4081;" />
                    <div class="feature-title">3. PR & Review</div>
                    <div class="feature-description">
                        Push your branch and submit a pull request for review by ATC members.
                    </div>
                </div>
            </MudItem>
        </MudGrid>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
            Be sure to merge with the latest code from upstream before making a pull request.
        </MudAlert>
        <MudText>
            See <MudLink Href="/introduction/getting-started#coding-guidelines">Coding Guidelines</MudLink> below for more details.
        </MudText>
    </SectionContent>
</DocsPageSection>