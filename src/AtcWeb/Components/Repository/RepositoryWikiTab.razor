@if (Repository?.Wiki.HasWiki == true)
{
    <MudGrid Spacing="4">
        @* Wiki content (same width as readme: lg=8) *@
        <MudItem xs="12" lg="8">
            <MudCard Elevation="0">
                @if (selectedPage is not null && selectedPage.IsLoaded)
                {
                    <MudCardContent>
                        <MarkdownRepositoryContent RepositoryName="@Repository.Name"
                                                   RepositoryBranch="@Repository.BaseData.DefaultBranch"
                                                   HeaderName="@GetWikiPageTitle(selectedPage)"
                                                   Content="@selectedPage.RawContent" />
                    </MudCardContent>
                }
                else
                {
                    <MudCardContent>
                        <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    </MudCardContent>
                }
            </MudCard>
        </MudItem>
        @* Wiki sidebar navigation (to the right, lg=4) *@
        <MudItem xs="12" lg="4">
            <MudCard Elevation="0" Class="repo-sidebar-card">
                <MudCardContent>
                    <MudNavMenu Dense="true">
                        @{
                            var grouped = GetGroupedPages();
                        }
                        @foreach (var group in grouped)
                        {
                            @if (!string.IsNullOrEmpty(group.Key))
                            {
                                <MudNavGroup Title="@GetGroupTitle(group.Key)" Expanded="true">
                                    @foreach (var page in group.Value)
                                    {
                                        var isActive = page == selectedPage;
                                        <MudNavLink OnClick="@(() => SelectPage(page))"
                                                    Match="NavLinkMatch.All"
                                                    Class="@(isActive ? "active" : "")">
                                            @(GetNavTitle(page))
                                        </MudNavLink>
                                    }
                                </MudNavGroup>
                            }
                            else
                            {
                                @foreach (var page in group.Value)
                                {
                                    var isActive = page == selectedPage;
                                    <MudNavLink OnClick="@(() => SelectPage(page))"
                                                Match="NavLinkMatch.All"
                                                Class="@(isActive ? "active" : "")">
                                        @(GetNavTitle(page))
                                    </MudNavLink>
                                }
                            }
                        }
                    </MudNavMenu>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}