@page "/news"

@using AtcWeb.Styles

<DocsPage MaxWidth="MaxWidth.Large">
    <DocsPageHeader Title="Recent Activity"
                    SubTitle="What's happening across the ATC-NET ecosystem.">
    </DocsPageHeader>
    <DocsPageContent>
        @if (repositories is null)
        {
            <MudGrid Justify="Justify.Center">
                <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
            </MudGrid>
        }
        else
        {
            var thisWeek = GetReposByRecency(d => d > DateTimeOffset.UtcNow.AddDays(-7));
            var thisMonth = GetReposByRecency(d => d <= DateTimeOffset.UtcNow.AddDays(-7) && d > DateTimeOffset.UtcNow.AddDays(-30));
            var thisQuarter = GetReposByRecency(d => d <= DateTimeOffset.UtcNow.AddDays(-30) && d > DateTimeOffset.UtcNow.AddDays(-90));
            var older = GetReposByRecency(d => d <= DateTimeOffset.UtcNow.AddDays(-90));

            @if (thisWeek.Any())
            {
                <div class="section-title mb-4" style="font-size: 20px;">This Week</div>
                <div class="featured-repos-grid mb-8">
                    @foreach (var repo in thisWeek)
                    {
                        @RenderRepoCard(repo)
                    }
                </div>
            }

            @if (thisMonth.Any())
            {
                <div class="section-title mb-4" style="font-size: 20px;">This Month</div>
                <div class="featured-repos-grid mb-8">
                    @foreach (var repo in thisMonth)
                    {
                        @RenderRepoCard(repo)
                    }
                </div>
            }

            @if (thisQuarter.Any())
            {
                <div class="section-title mb-4" style="font-size: 20px;">Past 3 Months</div>
                <div class="featured-repos-grid mb-8">
                    @foreach (var repo in thisQuarter)
                    {
                        @RenderRepoCard(repo)
                    }
                </div>
            }

            @if (older.Any())
            {
                <div class="section-title mb-4" style="font-size: 20px;">Earlier</div>
                <div class="featured-repos-grid mb-8">
                    @foreach (var repo in older)
                    {
                        @RenderRepoCard(repo)
                    }
                </div>
            }
        }
    </DocsPageContent>
</DocsPage>

@{
    RenderFragment RenderRepoCard(AtcRepository repo) =>
        @<a href="/repository/@repo.Name"
            class="repo-card @RepositoryCategoryHelper.GetCardCssClass(repo.Name)"
            style="text-decoration: none;">
            <div class="d-flex align-center gap-2 mb-2">
                <img src="@ImageHelper.GetProgramIconPathForLanguage(repo.BaseData.Language)"
                     width="20" height="20" alt="" />
                <div class="repo-card-name">@repo.Name</div>
                <MudText Typo="Typo.caption"
                         Style="margin-left: auto; opacity: 0.6; white-space: nowrap;">
                    @FormatRelativeTime(repo.BaseData.PushedAt)
                </MudText>
            </div>
            <div class="repo-card-description">
                @(string.IsNullOrEmpty(repo.Description) ? "No description available." : repo.Description)
            </div>
            <div class="repo-card-meta">
                @if (!string.IsNullOrEmpty(repo.BaseData.Language))
                {
                    <span>@repo.BaseData.Language</span>
                }
                @if (!string.IsNullOrEmpty(repo.BaseData.License?.Key))
                {
                    <span>@repo.BaseData.License.Key</span>
                }
                <span>@RepositoryCategoryHelper.GetCategory(repo.Name)</span>
            </div>
        </a>;
}
