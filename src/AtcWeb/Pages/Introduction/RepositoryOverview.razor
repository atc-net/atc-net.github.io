@page "/introduction/repository-overview"

@inherits RepositoryOverviewBase

<DocsPage MaxWidth="MaxWidth.Large">
    <DocsPageHeader Title="Repository overview"
                    SubTitle="All public repositories in the ATC-NET organization.">
    </DocsPageHeader>
    <DocsPageContent>
        @if (Repositories is null)
        {
            <MudGrid Justify="Justify.Center">
                <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
            </MudGrid>
        }
        else
        {
            <div class="featured-repos-grid">
                @foreach (var repository in Repositories
                    .Where(x => !x.BaseData.Private)
                    .OrderBy(x => x.Name))
                {
                    <a href="/repository/@repository.Name"
                       class="repo-card @RepositoryCategoryHelper.GetCardCssClass(repository.Name)"
                       style="text-decoration: none;">
                        <div class="d-flex align-center gap-2 mb-2">
                            <img src="@ImageHelper.GetProgramIconPathForLanguage(repository.BaseData.Language)"
                                 width="20" height="20" alt="" />
                            <div class="repo-card-name">@repository.Name</div>
                        </div>
                        <div class="repo-card-description">
                            @(string.IsNullOrEmpty(repository.Description) ? "No description available." : repository.Description)
                        </div>
                        <div class="repo-card-meta">
                            @if (!string.IsNullOrEmpty(repository.BaseData.Language))
                            {
                                <span>@repository.BaseData.Language</span>
                            }
                            @if (!string.IsNullOrEmpty(repository.BaseData.License?.Key))
                            {
                                <span>@repository.BaseData.License.Key</span>
                            }
                        </div>
                    </a>
                }
            </div>
        }
    </DocsPageContent>
</DocsPage>