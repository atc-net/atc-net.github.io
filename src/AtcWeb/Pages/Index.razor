@page "/"

<MudMainContent>
    @* ===== HERO SECTION ===== *@
    <section class="hero-section">
        <div class="hero-title">ATC-NET</div>
        <div class="hero-subtitle">A Touch of Class</div>
        <div class="hero-description">
            Open-source .NET libraries and tools built from years of real-world developer experience.
            Battle-tested, MIT licensed, and ready for your next project.
        </div>
        <div class="d-flex justify-center gap-3 flex-wrap">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Href="/introduction/repository-overview"
                       Class="hero-cta-primary">
                Explore Repositories
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Href="/introduction/about-atc"
                       Class="hero-cta-secondary">
                Get Started
            </MudButton>
        </div>
    </section>

    @* ===== STATS BAR ===== *@
    <div class="stats-bar">
        <div class="stat-item">
            <div class="stat-value">@(nugetStats is not null ? nugetStats.FormattedDownloads : "--")</div>
            <div class="stat-label">NuGet Downloads</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">@(nugetStats is not null ? $"{nugetStats.PackageCount}+" : "--")</div>
            <div class="stat-label">Libraries</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">@(repositoryCount > 0 ? $"{repositoryCount}+" : "--")</div>
            <div class="stat-label">Repositories</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">100%</div>
            <div class="stat-label">Open Source</div>
        </div>
    </div>

    <hr class="gradient-divider mx-auto mb-12" style="max-width: 200px;" />

    @* ===== FEATURED REPOS ===== *@
    <MudContainer MaxWidth="MaxWidth.Large" Class="mb-16">
        <div class="text-center mb-8">
            <div class="section-title">Featured Repositories</div>
            <div class="section-subtitle">The most popular packages in the ATC-NET ecosystem</div>
        </div>

        @if (featuredRepos is null)
        {
            <div class="featured-repos-grid">
                @for (var i = 0; i < 6; i++)
                {
                    <div class="repo-card repo-card-core" style="min-height: 140px;">
                        <MudSkeleton Width="60%" Height="24px" Class="mb-3" />
                        <MudSkeleton Width="90%" Height="16px" Class="mb-2" />
                        <MudSkeleton Width="75%" Height="16px" Class="mb-4" />
                        <MudSkeleton Width="30%" Height="14px" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="featured-repos-grid">
                @foreach (var repo in featuredRepos)
                {
                    <a href="/repository/@repo.Name" class="repo-card @RepositoryCategoryHelper.GetCardCssClass(repo.Name)" style="text-decoration: none;">
                        <div class="repo-card-name">@repo.Name</div>
                        <div class="repo-card-description">@(string.IsNullOrEmpty(repo.BaseData.Description) ? "A .NET library" : repo.BaseData.Description)</div>
                        <div class="repo-card-meta">
                            <span>@repo.BaseData.Language</span>
                            @if (!string.IsNullOrEmpty(repo.BaseData.License?.Key))
                            {
                                <span>@repo.BaseData.License.Key</span>
                            }
                        </div>
                    </a>
                }
            </div>
            <div class="text-center mt-6">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Href="/introduction/repository-overview"
                           EndIcon="@Icons.Material.Filled.ArrowForward">
                    View all @repositoryCount repositories
                </MudButton>
            </div>
        }
    </MudContainer>

    @* ===== WHY ATC-NET ===== *@
    <MudContainer MaxWidth="MaxWidth.Large" Class="mb-16">
        <div class="text-center mb-8">
            <div class="section-title">Why ATC-NET?</div>
            <div class="section-subtitle">Built by developers, for developers</div>
        </div>

        <MudGrid Spacing="4">
            <MudItem xs="12" sm="6" md="3">
                <div class="feature-card">
                    <MudIcon Icon="@Icons.Material.Filled.Verified"
                             Class="feature-icon"
                             Style="color: #776be7;" />
                    <div class="feature-title">Battle-Tested</div>
                    <div class="feature-description">
                        Built from years of real-world project experience across different customers and domains.
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="feature-card">
                    <MudIcon Icon="@Icons.Material.Filled.Code"
                             Class="feature-icon"
                             Style="color: #1ec8a5;" />
                    <div class="feature-title">Open Source</div>
                    <div class="feature-description">
                        MIT licensed. Fork it, use it, contribute to it. The code stays in GitHub forever.
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="feature-card">
                    <MudIcon Icon="@Icons.Material.Filled.Devices"
                             Class="feature-icon"
                             Style="color: #ff4081;" />
                    <div class="feature-title">Cross-Platform</div>
                    <div class="feature-description">
                        Support for Linux, macOS, and Windows. Built on .NET LTS with modern C# features.
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <div class="feature-card">
                    <MudIcon Icon="@Icons.Material.Filled.Groups"
                             Class="feature-icon"
                             Style="color: #ffa800;" />
                    <div class="feature-title">Community Driven</div>
                    <div class="feature-description">
                        Started by two colleagues sharing common code, now a growing community
                        of developers building and contributing together on GitHub.
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    </MudContainer>

</MudMainContent>