@using AtcWeb.Styles

<MudNavMenu Class="atc-navmenu">
    <div class="docs-nav-fader"></div>

    <MudNavLink Icon="@Icons.Material.Filled.Newspaper" Href="/news">News</MudNavLink>
    <MudNavGroup Title="Introduction"
                 Icon="@Icons.Material.Filled.School"
                 Expanded="@(section == "introduction")"
                 ExpandIcon="@Icons.Material.Filled.ExpandMore">
        <MudNavLink Href="/introduction/about-atc">Getting Started</MudNavLink>
        <MudNavLink Href="/introduction/repository-overview">Repository overview</MudNavLink>
    </MudNavGroup>
    <MudNavGroup Title="Tools"
                 Icon="@Icons.Material.Filled.Terminal"
                 Expanded="@(section == "tools")"
                 ExpandIcon="@Icons.Material.Filled.ExpandMore">
        <MudNavLink Href="/tools/cli-tools">CLI Tools</MudNavLink>
    </MudNavGroup>
    <MudNavGroup Title="Manuals"
                 Icon="@Icons.Material.Filled.School"
                 Expanded="@(section == "manuals")"
                 ExpandIcon="@Icons.Material.Filled.ExpandMore">
        <MudNavLink Href="/manuals/devops-playbook">DevOps Playbook</MudNavLink>
    </MudNavGroup>

    <MudTextField @bind-Value="searchText"
                  Placeholder="Filter repositories..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mx-3 mt-3 mb-2 nav-search-field"
                  Immediate="true"
                  Disabled="@(repositories is null)"
                  Style="font-size: 13px;" />

    @if (allGroups is null)
    {
        @* Show placeholder group headers to prevent layout jump *@
        <MudNavGroup Title="AI & Agents" Icon="@Icons.Material.Filled.Psychology" Disabled="true" />
        <MudNavGroup Title="Azure" Icon="@Icons.Material.Filled.Cloud" Disabled="true" />
        <MudNavGroup Title="Code Quality" Icon="@Icons.Material.Filled.Rule" Disabled="true" />
        <MudNavGroup Title="Core & Libraries" Icon="@Icons.Material.Filled.Hub" Disabled="true" />
        <MudNavGroup Title="Developer Tools" Icon="@Icons.Material.Filled.Construction" Disabled="true" />
        <MudNavGroup Title="Industrial" Icon="@Icons.Material.Filled.Factory" Disabled="true" />
        <MudNavGroup Title="IoT" Icon="@Icons.Material.Filled.Sensors" Disabled="true" />
        <MudNavGroup Title="REST & API" Icon="@Icons.Material.Filled.Api" Disabled="true" />
        <MudNavGroup Title="Testing" Icon="@Icons.Material.Filled.Science" Disabled="true" />
        <MudNavGroup Title="UI & Desktop" Icon="@Icons.Material.Filled.DesktopWindows" Disabled="true" />
    }
    else
    {
        @foreach (var group in allGroups)
        {
            var groupName = group.Key;
            var visible = GroupMatchesSearch(group.Value);
            var expanded = IsGroupExpanded(groupName);
            var filteredRepos = expanded ? GetFilteredRepos(group.Value) : null;
            <div style="@(visible ? "" : "display:none")">
                <MudNavGroup Title="@groupName"
                             Icon="@RepositoryCategoryHelper.GetIcon(groupName)"
                             Expanded="@expanded"
                             ExpandedChanged="@(value => OnGroupExpandedChanged(groupName, value))"
                             ExpandIcon="@Icons.Material.Filled.ExpandMore">
                    @if (filteredRepos is not null)
                    {
                        @foreach (var repository in filteredRepos)
                        {
                            var href = $"/repository/{repository.Name}";
                            var iconSrc = ImageHelper.GetProgramIconPathForLanguage(repository.BaseData.Language);

                            <MudElement HtmlTag="div"
                                        Class="mud-nav-item mud-ripple d-flex items-center">
                                <a href="@href" class="mud-nav-link">
                                    <img src="@iconSrc" width="20" height="20" alt="" />
                                    <MudText Class="mud-nav-link-text"
                                             Inline="true">
                                        @repository.Name
                                    </MudText>
                                </a>
                            </MudElement>
                        }
                    }
                </MudNavGroup>
            </div>
        }
    }

</MudNavMenu>